{
  "name": "@bepyan/arita",
  "version": "1.0.0",
  "description": "Arita typeface (아리따) served as web fonts via jsDelivr CDN",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bepyan/arita.git"
  },
  "homepage": "https://bepyan.github.io/arita",
  "keywords": [
    "arita",
    "아리따",
    "webfont",
    "korean-font",
    "font",
    "cdn"
  ],
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "cn-font-split"
    ]
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:static": "node scripts/build.mjs --only=static",
    "build:subset": "node scripts/build.mjs --only=subset",
    "sync:demo": "rm -rf public && mkdir -p public && cp -R dist public/dist",
    "dev": "pnpm run sync:demo && astro dev",
    "build:demo": "rm -rf public && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "deploy:demo": "pnpm dlx wrangler pages deploy .site --project-name=arita",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^7.1.1",
    "cn-font-split": "7.4.3",
    "typescript": "^6.0.3"
  }
}
