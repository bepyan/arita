---
import { Code } from 'astro:components';
import type { ComponentProps } from 'astro/types';

type Props = Pick<ComponentProps<typeof Code>, 'code' | 'lang'>;

const { code, lang } = Astro.props;
---

<div class="code-block">
  <Code code={code} lang={lang} theme="github-light" />
</div>

<script>
  const ICON_COPY = `<svg class="icon-copy" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg>`;
  const ICON_CHECK = `<svg class="icon-check" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L1.72 8.78a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/></svg>`;

  for (const block of document.querySelectorAll(".code-block")) {
    // Shiki가 코드를 여러 <span>으로 쪼개도 textContent는 원본을 그대로 복원한다.
    const source = block.querySelector("code")?.textContent ?? "";

    const btn = document.createElement("button");
    btn.className = "copy-btn";
    btn.type = "button";
    btn.setAttribute("aria-label", "코드 복사");
    btn.innerHTML = ICON_COPY + ICON_CHECK;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(source);
        btn.classList.add("copied");
        btn.setAttribute("aria-label", "복사됨");
        setTimeout(() => {
          btn.classList.remove("copied");
          btn.setAttribute("aria-label", "코드 복사");
        }, 1500);
      } catch (err) {
        console.warn("클립보드 복사 실패:", err);
      }
    });
    block.appendChild(btn);
  }
</script>
