---
import CodeBlock from '../components/code-block.astro';
import SpecimenGrid from '../components/specimen-grid.astro';
import { version } from '../../package.json';
import favicon from '../assets/favicon.svg';
import '../styles/global.css';

const TITLE = '아리따 글꼴(Typeface Arita)';
const DESCRIPTION =
  '아모레퍼시픽의 나눔 글꼴 아리따(Arita)를 링크 한 줄로 불러오는 비공식 웹폰트 CDN입니다.';
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL('/og.png', Astro.site);

// dev는 로컬 폰트 빌드(sync:demo → public/dist)로 배포 전 결과를 미리보고, 빌드는 CDN을 쓴다.
const FONT_CSS = import.meta.env.DEV
  ? '/dist/static/arita.css'
  : 'https://cdn.jsdelivr.net/npm/@bepyan/arita@latest/dist/dynamic-subset/arita-dynamic-subset.css';

const FONTS = [
  {
    id: 'dotum',
    label: '아리따 돋움',
    script: '한글',
    family: 'Arita Dotum KR',
    weights: '100 · 300 · 500 · 600 · 700',
    cssFile: 'arita-dotum-dynamic-subset.css',
  },
  {
    id: 'buri',
    label: '아리따 부리',
    script: '한글',
    family: 'Arita Buri KR',
    weights: '100 · 300 · 500 · 600 · 700',
    cssFile: 'arita-buri-dynamic-subset.css',
  },
  {
    id: 'sans-ltn',
    label: '아리따 산스',
    script: '라틴',
    family: 'Arita Sans LTN',
    weights: '100 · 300 · 500 · 600 · 700',
    cssFile: 'arita-sans-ltn-dynamic-subset.css',
  },
  {
    id: 'sans-sc',
    label: '아리따 흑체',
    script: '중문 간체',
    family: 'Arita Sans SC',
    weights: '300 · 500 · 700',
    cssFile: 'arita-sans-sc-dynamic-subset.css',
  },
];

const linkSnippet = (font: (typeof FONTS)[number]) => `<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@bepyan/arita@${version}/dist/dynamic-subset/${font.cssFile}"
/>`;

const cssSnippet = (font: (typeof FONTS)[number]) => `body {
  font-family: "${font.family}", sans-serif;
  font-weight: 500;
}`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:site_name" content="아리따 글꼴" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="naver-site-verification" content="1a73756ab947f4277a933e44856435b50c6866b6" />

    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="stylesheet" href={FONT_CSS} />
  </head>
  <body>
    <div class="sheet">
      <header class="masthead">
        <a class="brand" href="https://design.amorepacific.com/arita/" target="_blank" rel="noopener noreferrer">아리따</a>
        <p class="hero-desc">
          아모레퍼시픽의 나눔 글꼴{' '}
          <a href="https://design.amorepacific.com/arita/" target="_blank" rel="noopener noreferrer">아리따(Arita)</a>를
          링크 한 줄로 불러오는 <strong>비공식 웹폰트 CDN</strong>입니다.
        </p>
        <nav aria-label="주요 링크">
          <a href="https://github.com/bepyan/arita" target="_blank" rel="noopener noreferrer">GITHUB</a>
          <a href="https://github.com/bepyan/arita/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">LICENSE</a>
          <a href="https://www.npmjs.com/package/@bepyan/arita" target="_blank" rel="noopener noreferrer">NPM</a>
        </nav>
      </header>

      <main>
        <h1 class="sr-only">아리따 글꼴 — Arita Webfont CDN</h1>

        <section class="hero" aria-label="아리따 활자 견본">
          <div class="rail">
            <p><strong>활자 견본</strong>Type Specimen</p>
          </div>
          <SpecimenGrid />
        </section>

        <section id="usage" class="sheet-section row">
          <div class="rail">
            <h2>사용법<small>Getting Started</small></h2>
          </div>
          <div class="usage-body">
            <div class="step">
              <h3 class="step-title">1 · 글꼴 불러오기</h3>
              <p class="step-desc">
                필요한 글꼴의 CSS 링크를 <code>&lt;head&gt;</code>에 추가하세요.
              </p>
              <fieldset class="font-table-fieldset">
                <legend class="sr-only">글꼴 선택</legend>
                <div class="ref-table-wrap">
                  <table class="ref-table font-table">
                    <thead>
                      <tr>
                        <th>선택</th>
                        <th>글꼴</th>
                        <th><code>font-family</code></th>
                        <th><code>font-weight</code></th>
                        <th>CSS 파일명</th>
                      </tr>
                    </thead>
                    <tbody>
                      {FONTS.map((font, i) => (
                        <tr>
                          <td>
                            <input
                              type="radio"
                              name="font-select"
                              id={`font-${font.id}`}
                              value={font.id}
                              checked={i === 0}
                            />
                          </td>
                          <td><label for={`font-${font.id}`}>{font.label} <small>{font.script}</small></label></td>
                          <td><code>{font.family}</code></td>
                          <td>{font.weights}</td>
                          <td><code>{font.cssFile}</code></td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </fieldset>
              <div class="snippet">
                <p class="snippet-label">HTML</p>
                {FONTS.map((font) => (
                  <div class="font-panel" data-font={font.id}>
                    <CodeBlock code={linkSnippet(font)} lang="html" />
                  </div>
                ))}
              </div>
            </div>

            <div class="step">
              <h3 class="step-title">2 · 글꼴 적용하기</h3>
              <p class="step-desc">
                선택한 글꼴을 CSS에 적용하세요.<br />
                기본 굵기로는 <code>font-weight: 500</code>(Medium)을 권장합니다.
              </p>
              <div class="snippet">
                <p class="snippet-label">CSS</p>
                {FONTS.map((font) => (
                  <div class="font-panel" data-font={font.id}>
                    <CodeBlock code={cssSnippet(font)} lang="css" />
                  </div>
                ))}
              </div>
            </div>

            <div class="step">
              <h3 class="step-title">더 알아보기</h3>
              <p class="step-desc">
                기본 방식(dynamic subset)은 글꼴 파일 전체 대신 페이지에 실제 쓰인
                글자 조각만 내려받습니다. 한글처럼 글자 수가 많은 글꼴에 특히 유리하고,
                따로 설정할 것은 없습니다.
              </p>
              <div class="ref-table-wrap">
                <table class="ref-table">
                  <thead>
                    <tr>
                      <th>용도</th>
                      <th>경로</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>모든 글꼴을 한 번에</td>
                      <td><code>dist/dynamic-subset/arita-dynamic-subset.css</code></td>
                    </tr>
                    <tr>
                      <td>글꼴 파일을 통째로 (static)</td>
                      <td><code>dist/static/arita-dotum.css</code> 등 파일명 규칙 동일</td>
                    </tr>
                    <tr>
                      <td>모든 글꼴을 통째로</td>
                      <td><code>dist/static/arita.css</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

      </main>

      <footer>
        <p>글꼴 저작권 © AMOREPACIFIC</p>
        <ul class="footer-social">
          <li><a href="https://github.com/bepyan/arita" target="_blank" rel="noopener noreferrer">GITHUB</a></li>
          <li><a href="https://github.com/bepyan/arita/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">LICENSE</a></li>
          <li><a href="https://www.npmjs.com/package/@bepyan/arita" target="_blank" rel="noopener noreferrer">NPM</a></li>
        </ul>
      </footer>
    </div>
  </body>
</html>
