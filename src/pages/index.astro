---
import CodeBlock from '../components/code-block.astro';
import SpecimenGrid from '../components/specimen-grid.astro';
import { version } from '../../package.json';
import favicon from '../assets/favicon.svg';
import ogImage from '../assets/og.png';
import '../styles/global.css';

const TITLE = '아리따 글꼴(Typeface Arita)';
const DESCRIPTION =
  '아모레퍼시픽의 나눔 폰트 아리따(Arita)를 링크 한 줄로 불러오는 비공식 웹폰트 CDN입니다.';
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage.src, Astro.site);

// dev는 로컬 폰트 빌드(sync:demo → public/dist)로 배포 전 결과를 미리보고, 빌드는 CDN을 쓴다.
const FONT_CSS = import.meta.env.DEV
  ? '/dist/static/arita.css'
  : 'https://cdn.jsdelivr.net/npm/@bepyan/arita@latest/dist/dynamic-subset/arita-dynamic-subset.css';

const LINK_SNIPPET = `<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@bepyan/arita@${version}/dist/dynamic-subset/arita-dotum-dynamic-subset.css"
/>`;

const CSS_SNIPPET = `body {
  font-family: "Arita Dotum KR", sans-serif;
}`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:site_name" content="아리따 글꼴" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="stylesheet" href={FONT_CSS} />
  </head>
  <body>
    <div class="sheet">
      <header class="masthead">
        <a class="brand" href="https://design.amorepacific.com/arita/" target="_blank" rel="noopener noreferrer">아리따</a>
        <p class="hero-desc">
          아모레퍼시픽의 나눔 폰트{' '}
          <a href="https://design.amorepacific.com/arita/" target="_blank" rel="noopener noreferrer">아리따(Arita)</a>를
          링크 한 줄로 불러오는 <strong>비공식 웹폰트 CDN</strong>입니다.
        </p>
        <nav aria-label="주요 링크">
          <a href="https://github.com/bepyan/arita" target="_blank" rel="noopener noreferrer">GITHUB</a>
          <a href="https://github.com/bepyan/arita/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">LICENSE</a>
          <a href="https://www.npmjs.com/package/@bepyan/arita" target="_blank" rel="noopener noreferrer">NPM</a>
        </nav>
      </header>

      <main>
        <h1 class="sr-only">아리따 글꼴 — Arita Webfont CDN</h1>

        <section class="hero" aria-label="아리따 활자 견본">
          <div class="rail">
            <p><strong>활자 견본</strong>Type Specimen</p>
          </div>
          <SpecimenGrid />
        </section>

        <section id="usage" class="sheet-section row">
          <div class="rail">
            <h2>사용법<small>Getting Started</small></h2>
          </div>
          <div>
            <div class="step">
              <h3 class="step-title">1 · 글꼴 불러오기</h3>
              <p class="step-desc">
                쓰고 싶은 글꼴을 골라 <code>&lt;head&gt;</code>에 링크를 추가하세요.
                아래는 <strong>아리따 돋움</strong> 예시입니다. 다른 글꼴은 표에서 CSS 파일명만
                바꾸면 됩니다. 필요한 글꼴만 불러와야 페이지가 가볍습니다.
              </p>
              <div class="snippet">
                <p class="snippet-label">HTML</p>
                <CodeBlock code={LINK_SNIPPET} lang="html" />
              </div>
              <div class="ref-table-wrap">
                <table class="ref-table">
                  <thead>
                    <tr>
                      <th>글꼴</th>
                      <th><code>font-family</code></th>
                      <th><code>font-weight</code></th>
                      <th>CSS 파일명</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>아리따 돋움 <small>한글</small></td>
                      <td><code>Arita Dotum KR</code></td>
                      <td>100 · 300 · 500 · 600 · 700</td>
                      <td><code>arita-dotum-dynamic-subset.css</code></td>
                    </tr>
                    <tr>
                      <td>아리따 부리 <small>한글</small></td>
                      <td><code>Arita Buri KR</code></td>
                      <td>100 · 300 · 500 · 600 · 700</td>
                      <td><code>arita-buri-dynamic-subset.css</code></td>
                    </tr>
                    <tr>
                      <td>아리따 산스 <small>라틴</small></td>
                      <td><code>Arita Sans LTN</code></td>
                      <td>100 · 300 · 500 · 600 · 700</td>
                      <td><code>arita-sans-ltn-dynamic-subset.css</code></td>
                    </tr>
                    <tr>
                      <td>아리따 흑체 <small>중문 간체</small></td>
                      <td><code>Arita Sans SC</code></td>
                      <td>300 · 500 · 700</td>
                      <td><code>arita-sans-sc-dynamic-subset.css</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <div class="ref-note">
                <p class="ref-note-title">굵기 이름 매핑</p>
                <ul>
                  <li>Thin/HairLine → 100</li>
                  <li>Light → 300</li>
                  <li>Medium → 500</li>
                  <li>SemiBold → 600</li>
                  <li>Bold → 700</li>
                </ul>
              </div>
            </div>

            <div class="step">
              <h3 class="step-title">2 · 글꼴 적용하기</h3>
              <p class="step-desc">
                CSS에서 글꼴을 적용할 곳에 위 표의 <code>font-family</code> 이름을 쓰면 끝입니다.
              </p>
              <div class="snippet">
                <p class="snippet-label">CSS</p>
                <CodeBlock code={CSS_SNIPPET} lang="css" />
              </div>
            </div>

            <div class="step">
              <h3 class="step-title">더 알아보기</h3>
              <p class="step-desc">
                기본 방식(dynamic subset)은 글꼴 파일 전체 대신 페이지에 실제 쓰인
                글자 조각만 내려받습니다. 한글처럼 글자 수가 많은 글꼴에 특히 유리하고,
                따로 설정할 것은 없습니다.
              </p>
              <div class="ref-table-wrap">
                <table class="ref-table">
                  <thead>
                    <tr>
                      <th>용도</th>
                      <th>경로</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>모든 글꼴을 한 번에</td>
                      <td><code>dist/dynamic-subset/arita-dynamic-subset.css</code></td>
                    </tr>
                    <tr>
                      <td>글꼴 파일을 통째로 (static)</td>
                      <td><code>dist/static/arita-dotum.css</code> 등 파일명 규칙 동일</td>
                    </tr>
                    <tr>
                      <td>모든 글꼴을 통째로</td>
                      <td><code>dist/static/arita.css</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

      </main>

      <footer>
        <p>폰트 저작권 © AMOREPACIFIC</p>
        <ul class="footer-social">
          <li><a href="https://github.com/bepyan/arita" target="_blank" rel="noopener noreferrer">GITHUB</a></li>
          <li><a href="https://github.com/bepyan/arita/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">LICENSE</a></li>
          <li><a href="https://www.npmjs.com/package/@bepyan/arita" target="_blank" rel="noopener noreferrer">NPM</a></li>
        </ul>
      </footer>
    </div>
  </body>
</html>
